# GitVerified Environment Configuration
# Copy this file to .env and update values for your environment

# GitHub Personal Access Token (recommended for batch use)
# Without this, GitHub API is limited to 60 requests/hour.
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_your_token_here

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development

# Ollama Configuration
# Timeout (in seconds) for calls to the local Ollama LLM.
# Increase this on slow hardware or when using large models.
# Default: 90
# OLLAMA_TIMEOUT=90

# Logging Configuration
LOG_LEVEL=INFO
